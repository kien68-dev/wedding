{
  "name": "wedding-manager-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.0",
    "cookie-parser": "^1.4.0",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.0.0",
    "glob": "^10.4.5",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.1",
    "lru-cache": "^10.2.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.1",
    "prisma": "^5.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/compression": "^1.6.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.8.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.8.0",
    "@types/swagger-jsdoc": "^6.0.0",
    "@types/swagger-ui-express": "^4.0.0",
    "eslint": "^9.14.0",
    "husky": "^8.0.0",
    "prettier": "^3.3.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
